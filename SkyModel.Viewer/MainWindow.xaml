<Window x:Class="SkyModel.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sky Model Viewer"
        Icon="Assets/UIEye.ico"
        Height="760"
        Width="1280"
        MinHeight="620"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F7"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D9DEE6" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2864D8" />
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1F55BC" />
        </Style>
        <Style x:Key="SingleLineTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="RenderModeButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E9EFFA" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2D5FD3" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#214DB1" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#98A2B3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style x:Key="MetaTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" MinWidth="240" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" MinWidth="420" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,14" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#111827" Text="Sky Model Viewer" />
                <TextBlock Style="{StaticResource MetaTextStyle}" Text="Local Assets" />
            </StackPanel>
            <Border DockPanel.Dock="Right" Background="#E8EEF8" BorderBrush="#D1DBEE" BorderThickness="1" CornerRadius="6" Padding="10,5" VerticalAlignment="Center">
                <TextBlock Name="StatusText" Foreground="#34415D" Text="Ready" />
            </Border>
        </DockPanel>

        <Border Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" Margin="0,0,10,0" Text="Install Location" />
                <TextBox Name="InstallPathBox"
                         Style="{StaticResource SingleLineTextBoxStyle}"
                         Grid.Column="1"
                         Text=""
                         ToolTip="Path to the Sky install or extracted asset tree" />
                <Button Name="BrowseInstallLocationButton"
                        Grid.Column="2"
                        Content="Browse..."
                        Click="BrowseInstallLocationButton_Click"
                        Margin="10,0,0,0" />
                <Button Name="ScanButton"
                        Grid.Column="3"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Index Assets"
                        Click="ScanButton_Click"
                        Margin="10,0,0,0" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
            <DockPanel LastChildFill="True">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Asset Browser" />
                        <TextBlock Name="MeshCountText" Style="{StaticResource MetaTextStyle}" Text="No index loaded" />
                    </StackPanel>
                </DockPanel>
                <TextBox Name="MeshSearchBox"
                         Style="{StaticResource SingleLineTextBoxStyle}"
                         DockPanel.Dock="Top"
                         Margin="0,0,0,8"
                         TextChanged="MeshSearchBox_TextChanged"
                         ToolTip="Filter meshes by name or path" />
                <TreeView Name="MeshTree"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectedItemChanged="MeshTree_SelectedItemChanged"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True" />
            </DockPanel>
        </Border>

        <GridSplitter Grid.Row="2"
                      Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#E2E8F0"
                      ShowsPreview="True" />

        <Grid Grid.Row="2" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="240" />
                <RowDefinition Height="6" />
                <RowDefinition Height="240" MinHeight="140" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Padding="0">
                <DockPanel LastChildFill="True">
                    <DockPanel DockPanel.Dock="Top" Margin="10,10,10,8" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Name="SelectionTitle" Style="{StaticResource SectionTitleStyle}" Text="No mesh selected" />
                            <TextBlock Name="SelectionMeta" Style="{StaticResource MetaTextStyle}" Text="" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource MetaTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0" Text="View" />
                            <Border Background="#F2F4F7"
                                    BorderBrush="#D0D5DD"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    ClipToBounds="True">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Name="TextureModeButton"
                                                 Style="{StaticResource RenderModeButtonStyle}"
                                                 GroupName="RenderMode"
                                                 Content="Texture"
                                                 Tag="Texture"
                                                 IsChecked="True"
                                                 Checked="RenderModeButton_Checked" />
                                    <Border Width="1" Background="#D0D5DD" />
                                    <RadioButton Name="SolidModeButton"
                                                 Style="{StaticResource RenderModeButtonStyle}"
                                                 GroupName="RenderMode"
                                                 Content="Solid"
                                                 Tag="Solid"
                                                 Checked="RenderModeButton_Checked" />
                                    <Border Width="1" Background="#D0D5DD" />
                                    <RadioButton Name="WireModeButton"
                                                 Style="{StaticResource RenderModeButtonStyle}"
                                                 GroupName="RenderMode"
                                                 Content="Wire"
                                                 Tag="Wire"
                                                 Checked="RenderModeButton_Checked" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                    <Border Background="#11151C"
                            BorderBrush="#0B0F15"
                            BorderThickness="1,1,1,0"
                            MouseDown="ViewportHost_MouseDown"
                            MouseUp="ViewportHost_MouseUp"
                            MouseMove="ViewportHost_MouseMove"
                            MouseWheel="ViewportHost_MouseWheel"
                            MouseLeave="ViewportHost_MouseLeave">
                        <Viewport3D Name="MeshViewport" ClipToBounds="True" Focusable="True">
                            <ModelVisual3D x:Name="SceneVisual" />
                        </Viewport3D>
                    </Border>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="1"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E2E8F0"
                          ShowsPreview="True" />

            <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6" Text="Selection Details" />
                    <TextBox Name="DetailsBox"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="#F8FAFC"
                             Padding="8"
                             VerticalContentAlignment="Top"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="12" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
