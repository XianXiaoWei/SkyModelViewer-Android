<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app">

    <!-- ===== TOP: Functional buttons bar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_panel"
        android:padding="8dp">

        <!-- Row 1: Source buttons + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnChooseApk"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/choose_apk"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:minWidth="90dp" />

            <Button
                android:id="@+id/btnChooseInstalled"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/choose_installed"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:layout_marginStart="6dp"
                android:minWidth="90dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/status_ready"
                android:textSize="12sp"
                android:textColor="#34415D"
                android:background="@color/status_bg"
                android:padding="6dp"
                android:layout_marginStart="6dp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Row 2: Source path + mesh count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/sourcePathText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/status_select_source"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:singleLine="true"
                android:ellipsize="middle"
                android:padding="4dp" />

            <TextView
                android:id="@+id/meshCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_index_loaded"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Row 3: View mode + export buttons (horizontally scrollable) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/selectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="120dp"
                android:text="@string/no_mesh_selected"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:singleLine="true"
                android:ellipsize="end" />

            <RadioGroup
                android:id="@+id/viewModeGroup"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/btnTexture"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/view_texture"
                    android:textSize="11sp"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/btnSolid"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/view_solid"
                    android:textSize="11sp" />

                <RadioButton
                    android:id="@+id/btnWire"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/view_wire"
                    android:textSize="11sp" />
            </RadioGroup>

            <Button
                android:id="@+id/btnExport"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/export"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:minWidth="72dp"
                android:enabled="false" />

            <Button
                android:id="@+id/btnBatchExport"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/batch_export"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:layout_marginStart="4dp"
                android:minWidth="72dp"
                android:enabled="false" />

            <Button
                android:id="@+id/btnToggleBeamo"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Beamo:ON"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:layout_marginStart="4dp"
                android:minWidth="56dp" />
        </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- ===== MIDDLE: 3D Viewport (largest area) ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:background="@color/bg_dark">

        <com.sky.modelviewer.render.MeshSurfaceView
            android:id="@+id/meshViewport"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/selectionMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="6dp"
            android:textSize="11sp"
            android:textColor="#80FFFFFF"
            android:text="" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="6dp"
            android:text="拖动: 旋转 | 双指: 平移/缩放"
            android:textColor="#60FFFFFF"
            android:textSize="10sp" />

        <!-- Left side: Virtual joystick for horizontal movement -->
        <FrameLayout
            android:id="@+id/joystickArea"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/joystickBase"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/joystick_bg" />

            <View
                android:id="@+id/joystickThumb"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/joystick_thumb" />
        </FrameLayout>

        <!-- Right side: Up/Down buttons for vertical movement -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="60dp">

            <Button
                android:id="@+id/btnMoveUp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▲"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="#80000000"
                android:padding="0dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp" />

            <Button
                android:id="@+id/btnMoveDown"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▼"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="#80000000"
                android:padding="0dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ===== BOTTOM: Mesh file list ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:background="@color/bg_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asset_browser"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <EditText
                android:id="@+id/searchBox"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:hint="@string/filter_meshes"
                android:textSize="12sp"
                android:padding="6dp"
                android:background="#F8FAFC"
                android:singleLine="true"
                android:inputType="text"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Column 1: Models (mesh) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="模型"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:background="#F3F4F6"
                    android:padding="4dp"
                    android:gravity="center" />

                <ListView
                    android:id="@+id/listMesh"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fastScrollEnabled="true"
                    android:scrollbars="vertical" />
            </LinearLayout>

            <!-- Column 2: Textures (ktx) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="贴图"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#065F46"
                    android:background="#D4F0DD"
                    android:padding="4dp"
                    android:gravity="center" />

                <ListView
                    android:id="@+id/listKtx"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fastScrollEnabled="true"
                    android:scrollbars="vertical" />
            </LinearLayout>

            <!-- Column 3: Maps (level) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="地图"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1E40AF"
                    android:background="#E0EAFB"
                    android:padding="4dp"
                    android:gravity="center" />

                <ListView
                    android:id="@+id/listLevel"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fastScrollEnabled="true"
                    android:scrollbars="vertical" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#F8FAFC">

            <TextView
                android:id="@+id/detailsBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:typeface="monospace"
                android:textColor="@color/text_primary"
                android:padding="6dp"
                android:text="选择模型查看详情" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>
