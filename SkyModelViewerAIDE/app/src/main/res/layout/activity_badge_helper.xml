<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app">

    <!-- ===== 顶部栏 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_card"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:elevation="2dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="返回"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/btn_secondary_bg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/badge_helper"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnFloating"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="悬浮窗"
            android:textColor="@color/btn_primary_text"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/btn_primary_bg" />
    </LinearLayout>

    <!-- ===== Tab 切换栏 ===== -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:gravity="center">

        <Button
            android:id="@+id/btnTab0"
            style="@style/SkyButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="32dp"
            android:text="我的徽章"
            android:textSize="13sp"
            android:minHeight="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnTab1"
            style="@style/SkyButton.Secondary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="32dp"
            android:text="徽章图鉴"
            android:textSize="13sp"
            android:minHeight="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp" />
    </LinearLayout>

    <!-- ===== Tab0 我的徽章 ===== -->
    <LinearLayout
        android:id="@+id/tab0Content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- 渠道选择 -->
        <HorizontalScrollView
            android:id="@+id/channelScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/bg_card"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <LinearLayout
                android:id="@+id/channelBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </HorizontalScrollView>

        <!-- NFC 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@color/bg_card"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnReadNfc"
                style="@style/SkyButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="38dp"
                android:text="读取NFC"
                android:textSize="13sp"
                android:minHeight="0dp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnManualInput"
                style="@style/SkyButton.Secondary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="38dp"
                android:text="手动输入"
                android:textSize="13sp"
                android:minHeight="0dp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- NFC 状态文本 -->
        <TextView
            android:id="@+id/tvNfcStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NFC: 就绪"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp" />

        <!-- 已存储数量文本 -->
        <TextView
            android:id="@+id/tvStoredCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="已存储: 0 个徽章"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp" />

        <!-- 已存储徽章列表 -->
        <ListView
            android:id="@+id/listStoredBadge"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fastScrollEnabled="true"
            android:scrollbars="vertical"
            android:background="@color/bg_card"
            android:divider="@color/divider"
            android:dividerHeight="1dp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- ===== Tab1 徽章图鉴 ===== -->
    <LinearLayout
        android:id="@+id/tab1Content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- 搜索框 -->
        <EditText
            android:id="@+id/searchBadge"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:hint="搜索徽章..."
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/search_bg"
            android:singleLine="true"
            android:inputType="text"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <!-- 分类栏 -->
        <HorizontalScrollView
            android:id="@+id/categoryScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/bg_card"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/categoryBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </HorizontalScrollView>

        <!-- 数量文本 -->
        <TextView
            android:id="@+id/tvBadgeCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="共 0 个徽章"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp" />

        <!-- 徽章图鉴列表 -->
        <ListView
            android:id="@+id/listBadge"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fastScrollEnabled="true"
            android:scrollbars="vertical"
            android:background="@color/bg_card"
            android:divider="@color/divider"
            android:dividerHeight="1dp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
