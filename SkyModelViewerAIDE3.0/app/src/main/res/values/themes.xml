<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SkyModelViewer" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg_app</item>
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_dark</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:buttonStyle">@style/SkyButton</item>
        <item name="android:radioButtonStyle">@style/SkyRadioButton</item>
    </style>

    <style name="SkyButton" parent="@android:style/Widget.Material.Light.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/btn_primary_text</item>
        <item name="android:background">@drawable/btn_primary_bg</item>
        <item name="android:minHeight">38dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="SkyButton.Secondary">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:background">@drawable/btn_secondary_bg</item>
    </style>

    <style name="SkyButton.Disabled">
        <item name="android:textColor">@color/btn_disabled_text</item>
        <item name="android:background">@drawable/btn_disabled_bg</item>
    </style>

    <style name="SkyRadioButton" parent="@android:style/Widget.Material.Light.CompoundButton.RadioButton">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:minHeight">32dp</item>
    </style>

    <style name="CardSection">
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="TabHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="OverlayButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/overlay_text</item>
        <item name="android:background">@drawable/move_btn_bg</item>
        <item name="android:padding">0dp</item>
    </style>
</resources>
